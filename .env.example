# Groq API Configuration (Optional - fallback provider)
GROQ_API_KEY=your_groq_api_key_here

# Hugging Face API Configuration (Optional - primary provider, works without API key)
HF_API_KEY=your_huggingface_api_key_here

# OpenAI API Configuration (Optional - fallback provider)
OPENAI_API_KEY=your_openai_api_key_here

# AssemblyAI API Configuration (Optional - fallback provider)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Transcription Provider Configuration
TRANSCRIPTION_PROVIDERS=huggingface,groq
DEFAULT_TRANSCRIPTION_PROVIDER=huggingface
TRANSCRIPTION_TIMEOUT_MS=300000
TRANSCRIPTION_RETRY_COUNT=3
TRANSCRIPTION_MAX_CONCURRENCY=2

# OpenRouter API Configuration (for text post-processing)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1:free

# Audio Processing Configuration
MAX_CONCURRENCY=3
CHUNK_SECONDS=45
CHUNK_OVERLAP=0.2
